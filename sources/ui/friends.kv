<DemandeAmis>:
    orientation: "vertical"
    spacing: "12dp"
    size_hint_y: None
    height: "500dp"
    MDIconButton:
        icon: "close-circle"
        pos_hint: {"right": 1, "top": 1}
        theme_text_color: "Custom"
        text_color: app.primary
        on_release: app.fermer_menu()

    MDLabel:
        text: "Mes Demandes"
        font_style: "Subtitle1"
        bold: True
        theme_text_color: "Custom"
        text_color: app.primary
        size_hint_y: None
        height: "28dp"

    MDScrollView:
        size_hint: 1, 1

        MDList:
            id: liste_demandes
            size_hint_y: None
            height: self.minimum_height


<FriendsMenu>:
    orientation: "vertical"
    #padding: "16dp"
    spacing: "12dp"
    size_hint_y: None
    height: "500dp"
    MDIconButton:
        icon: "close-circle"
        pos_hint: {"right": 1, "top": 1}
        theme_text_color: "Custom"
        text_color: app.primary
        on_release: app.fermer_menu()

    MDLabel:
        text: "Mes amis"
        font_style: "Subtitle1"
        bold: True
        theme_text_color: "Custom"
        text_color: app.primary
        size_hint_y: None
        height: "28dp"

    ScrollView:
        size_hint_y: None
        height: "220dp"

        MDList:
            id: liste_amis

    Widget:
        size_hint_y: None
        height: "1dp"
        canvas:
            Color:
                rgba: 0.7, 0.7, 0.7, 1
            Rectangle:
                pos: self.pos
                size: self.size

    MDLabel:
        text: "Ajouter un ami"
        font_style: "Subtitle1"
        bold: True
        theme_text_color: "Custom"
        text_color: app.primary
        size_hint_y: None
        height: "28dp"

    MDTextField:
        id: nom_amis
        hint_text: "Nom d'utilisateur"
        line_color_focus: app.primary
        size_hint_y: None
        height: "45dp"

    MDRaisedButton:
        text: "Envoyer la demande"
        md_bg_color: app.primary
        text_color: 1,1,1,1
        size_hint_x: 1
        on_release: app.envoyer_demande(nom_amis.text)

    Widget:
        size_hint_y: None
        height: "1dp"
        canvas:
            Color:
                rgba: 0.7, 0.7, 0.7, 1
            Rectangle:
                pos: self.pos
                size: self.size

    MDFlatButton:
        text: "Voir les demandes reçues"
        theme_text_color: "Custom"
        text_color: app.secondary
        size_hint_x: 1
        on_release: app.menu_demande_amis()
