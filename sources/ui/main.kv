<MainScreen>:
    name: "main"

    # fond d'écran
    canvas.before:
        Color:
            rgba: app.background
        Rectangle:
            pos: self.pos
            size: self.size

    # barre de navigation
    MDBottomNavigation:
        id: bottom_nav
        panel_color: app.primary
        text_color_active: 1,1,1,1
        text_color_normal: app.accent

        HomeTab:
            name: "home"
            text: "Accueil"
            icon: "home"

        AddTab:
            name: "add"
            text: "Ajouter"
            icon: "plus"

        LeaderboardTab:
            name: "leaderboard"
            text: "Classement"
            icon: "trophy"

        ProfileTab:
            name: "profile"
            text: "Compte"
            icon: "account"


<HomeTab>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        MDIconButton:
            icon: "account-group"
            pos_hint: {"right": 1, "top": 1}
            theme_text_color: "Custom"
            text_color: app.primary
            on_release: app.menu_amis()

        MDBoxLayout:
            orientation: "vertical"
            padding: "20dp"
            spacing: "16dp"
            pos_hint: {"center_x": .5, "center_y": .5}
            size_hint: 0.9, None
            height: self.minimum_height

            MDLabel:
                text: "Bienvenue, " + app.pseudo + " !"
                theme_text_color: "Custom"
                text_color: app.primary
                font_style: "H5"
                halign: "center"
                size_hint_y: None
                height: "40dp"

            # co2 de la semaine
            MDCard:
                orientation: "vertical"
                padding: "16dp"
                md_bg_color: app.background
                elevation: 1
                size_hint_y: None
                height: "80dp"

                MDLabel:
                    id: label_co2_semaine
                    text: "Chargement..."
                    theme_text_color: "Custom"
                    text_color: app.primary
                    font_style: "H6"
                    halign: "center"

            # message motivant
            MDCard:
                orientation: "vertical"
                padding: "16dp"
                md_bg_color: app.background
                elevation: 1
                size_hint_y: None
                height: "100dp"

                MDLabel:
                    id: label_message
                    text: ""
                    theme_text_color: "Custom"
                    text_color: app.secondary
                    font_size: "13sp"
                    halign: "center"
                    text_size: self.width, None
                    size_hint_y: None
                    height: self.texture_size[1]




<ProfileTab>:
    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        MDLabel:
            text: "Mon Profil"
            theme_text_color: "Custom"
            text_color: app.primary
            font_style: "H5"
            halign: "center"
            size_hint_y: None
            height: "50dp"

        MDRaisedButton:
            text: "Se déconnecter"
            md_bg_color: app.primary
            text_color: 1,1,1,1
            size_hint_x: 1
            on_release: app.deconnexion()

        MDCard:
            orientation: "vertical"
            padding: "20dp"
            spacing: "15dp"
            md_bg_color: app.background
            elevation: 1
            size_hint_y: None
            height: "360dp"

            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"
                MDLabel:
                    text: "Nom d'utilisateur"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"
                MDLabel:
                    text: app.pseudo
                    theme_text_color: "Custom"
                    text_color: app.primary
                    font_style: "H6"
                    size_hint_y: None
                    height: "30dp"

            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"
                MDLabel:
                    text: "Email"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"
                MDLabel:
                    text: app.mail
                    theme_text_color: "Custom"
                    text_color: app.secondary
                    font_size: "13sp"
                    size_hint_y: None
                    height: "30dp"

            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"
                MDLabel:
                    text: "Nombre d'amis"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"
                MDLabel:
                    text: app.nb_amis
                    theme_text_color: "Custom"
                    text_color: app.accent
                    font_style: "H6"
                    size_hint_y: None
                    height: "30dp"

            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"
                MDLabel:
                    text: "Empreinte carbone totale"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"
                MDLabel:
                    text: app.co2_total + " kg CO2"
                    theme_text_color: "Custom"
                    text_color: app.primary
                    font_style: "H6"
                    size_hint_y: None
                    height: "30dp"

        # espace vide pour pousser la carte vers le haut
        Widget:







<AddTab>:
    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        orientation: "vertical"
        padding: "12dp"
        spacing: "10dp"

        MDLabel:
            text: "Ajouter une empreinte"
            theme_text_color: "Custom"
            text_color: app.primary
            font_style: "H6"
            halign: "center"
            size_hint_y: None
            height: "36dp"


        Spinner:
            id: category_spinner
            text: "Toutes"
            values: ["Toutes"]
            size_hint_y: None
            height: "40dp"
            background_color: app.secondary
            color: 1, 1, 1, 1
            on_text: root.rechercher()



        MDBoxLayout:
            size_hint_y: None
            height: "48dp"
            spacing: "6dp"
            MDTextField:
                id: search_field
                hint_text: "Rechercher une activité…"
                on_text: root.rechercher()
                mode: "rectangle"


            MDIconButton:
                icon: "magnify"
                theme_icon_color: "Custom"
                icon_color: app.primary
                on_release: root.rechercher()

        RecycleView:
            id: activities_list
            size_hint_y: 0.45
            viewclass: "ActivityItem"
            RecycleBoxLayout:
                orientation: "vertical"
                spacing: "4dp"
                padding: "2dp"
                default_size_hint: 1, None
                default_size: None, "64dp"
                size_hint_y: None
                height: self.minimum_height



        MDSeparator:
            size_hint_y: None
            height: "1dp"

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "120dp"
            spacing: "6dp"

            MDLabel:
                id: selected_label
                text: "Aucune activité sélectionnée"
                theme_text_color: "Custom"
                text_color: app.secondary
                font_size: "13sp"
                markup: True
                halign: "center"
                size_hint_y: None
                height: "28dp"



            MDTextField:
                id: quantity_field
                hint_text: "Quantité"
                input_filter: "float"
                disabled: True
                mode: "rectangle"
                size_hint_y: None
                height: "48dp"

            MDRaisedButton:
                id: valider_btn
                text: "Valider"
                md_bg_color: app.primary
                text_color: 1, 1, 1, 1
                disabled: True
                size_hint_x: 1
                on_release: root.valider()

        MDLabel:
            id: feedback_label
            text: ""
            theme_text_color: "Custom"
            text_color: app.secondary
            font_size: "13sp"
            halign: "center"
            size_hint_y: None
            height: "24dp"











<LeaderboardTab>:
    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        orientation: "vertical"
        padding: "12dp"
        spacing: "10dp"


        MDBoxLayout:
            size_hint_y: None
            height: "48dp"
            spacing: "8dp"

            MDLabel:
                text: "Classement"
                theme_text_color: "Custom"
                text_color: app.primary
                font_style: "H6"
                halign: "center"

        MDBoxLayout:
            size_hint_y: None
            height: "48dp"
            spacing: "8dp"
            pos_hint: {"center_x": 0.65}
            size_hint_x: None
            width: "300dp"

            MDRaisedButton:
                text: "Total"
                pos_hint: {"center_y": 0.5}
                theme_icon_color: "Custom"
                icon_color: app.secondary
                size_hint_x: None
                width: "40dp"
                on_release: root.charger_classement()
            MDRaisedButton:
                text: "7 jours"
                pos_hint: {"center_y": 0.5}
                theme_icon_color: "Custom"
                icon_color: app.secondary
                size_hint_x: None
                width: "40dp"
                on_release: root.charger_classement(7)
            MDRaisedButton:
                text: "1 mois"
                pos_hint: {"center_y": 0.5}
                theme_icon_color: "Custom"
                icon_color: app.secondary
                size_hint_x: None
                width: "40dp"
                on_release: root.charger_classement(31)

        MDLabel:
            text: "Le moins de CO2 = le meilleur !"
            font_size: "12sp"
            theme_text_color: "Custom"
            text_color: app.secondary
            halign: "center"
            size_hint_y: None
            height: "24dp"

        MDSeparator:
            size_hint_y: None
            height: "1dp"



        ScrollView:
            RecycleView:
                id: leaderboard_list
                viewclass: "LeaderboardRow"
                RecycleBoxLayout:
                    orientation: "vertical"
                    spacing: "6dp"
                    padding: "4dp"
                    default_size_hint: 1, None
                    default_size: None, "60dp"
                    size_hint_y: None
                    height: self.minimum_height

