#Projet : TerraGauge
#Auteurs : Léo Diotallevi, Patrick Addison, Maël Yvetot


# ce fichier définit l'apparence de l'écran principal et de ses onglets :
# - MainScreen : l'écran avec la barre de navigation du bas
# - HomeTab : onglet accueil
# - ProfileTab : onglet profil utilisateur
# - AddTab : onglet pour ajouter une activité
# - LeaderboardTab : onglet classement entre amis


# ---- écran principal avec la barre de navigation ----
<MainScreen>:
    name: "main"

    # fond de l'écran
    canvas.before:
        Color:
            rgba: app.background
        Rectangle:
            pos: self.pos
            size: self.size

    # la barre de navigation du bas avec les 4 onglets
    MDBottomNavigation:
        id: bottom_nav
        panel_color: app.primary          # couleur de fond de la barre
        text_color_active: 1,1,1,1       # texte blanc pour l'onglet actif
        text_color_normal: app.accent     # texte vert clair pour les onglets inactifs

        HomeTab:
            name: "home"
            text: "Accueil"
            icon: "home"

        AddTab:
            name: "add"
            text: "Ajouter"
            icon: "plus"

        LeaderboardTab:
            name: "leaderboard"
            text: "Classement"
            icon: "trophy"

        ProfileTab:
            name: "profile"
            text: "Compte"
            icon: "account"








<HomeTab>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        # bouton amis en haut à droite
        MDIconButton:
            icon: "account-group"
            pos_hint: {"right": 1, "top": 1}
            theme_text_color: "Custom"
            text_color: app.primary
            on_release: app.menu_amis()

        MDBoxLayout:
            orientation: "vertical"
            padding: "20dp"
            spacing: "16dp"
            pos_hint: {"center_x": .5, "center_y": .5}
            size_hint: 0.9, None
            height: self.minimum_height

            MDLabel:
                text: "Bienvenue, " + app.pseudo + " !"
                theme_text_color: "Custom"
                text_color: app.primary
                font_style: "H5"
                halign: "center"
                size_hint_y: None
                height: "40dp"

            # co2 de la semaine
            MDCard:
                orientation: "vertical"
                padding: "16dp"
                md_bg_color: app.background
                elevation: 1
                size_hint_y: None
                height: "80dp"

                MDLabel:
                    id: label_co2_semaine
                    text: "Chargement..."
                    theme_text_color: "Custom"
                    text_color: app.primary
                    font_style: "H6"
                    halign: "center"

            # message motivant
            MDCard:
                orientation: "vertical"
                padding: "16dp"
                md_bg_color: app.background
                elevation: 1
                size_hint_y: None
                height: "100dp"

                MDLabel:
                    id: label_message
                    text: ""
                    theme_text_color: "Custom"
                    text_color: app.secondary
                    font_size: "13sp"
                    halign: "center"
                    # obligé de mettre ça sinon le texte dépasse
                    text_size: self.width, None
                    size_hint_y: None
                    height: self.texture_size[1]




# ---- onglet profil ----
<ProfileTab>:
    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        MDLabel:
            text: "Mon Profil"
            theme_text_color: "Custom"
            text_color: app.primary
            font_style: "H5"
            halign: "center"
            size_hint_y: None
            height: "50dp"

        MDRaisedButton:
            text: "Se déconnecter"
            md_bg_color: app.primary
            text_color: 1,1,1,1
            size_hint_x: 1
            on_release: app.deconnexion()

        # carte avec les infos du profil
        MDCard:
            orientation: "vertical"
            padding: "20dp"
            spacing: "15dp"
            md_bg_color: app.background
            elevation: 1
            size_hint_y: None
            height: "360dp"

            # nom d'utilisateur
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"
                MDLabel:
                    text: "Nom d'utilisateur"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"
                MDLabel:
                    text: app.pseudo
                    theme_text_color: "Custom"
                    text_color: app.primary
                    font_style: "H6"
                    size_hint_y: None
                    height: "30dp"

            # email
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"
                MDLabel:
                    text: "Email"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"
                MDLabel:
                    text: app.mail
                    theme_text_color: "Custom"
                    text_color: app.secondary
                    font_size: "13sp"
                    size_hint_y: None
                    height: "30dp"

            # nombre d'amis
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"
                MDLabel:
                    text: "Nombre d'amis"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"
                MDLabel:
                    text: app.nb_amis
                    theme_text_color: "Custom"
                    text_color: app.accent
                    font_style: "H6"
                    size_hint_y: None
                    height: "30dp"

            # empreinte carbone totale
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"
                MDLabel:
                    text: "Empreinte carbone totale"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"
                MDLabel:
                    text: app.co2_total + " kg CO2"
                    theme_text_color: "Custom"
                    text_color: app.primary
                    font_style: "H6"
                    size_hint_y: None
                    height: "30dp"

        # espace vide pour pousser la carte vers le haut
        Widget:







# ---- onglet ajouter une activité ----
<AddTab>:
    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        orientation: "vertical"
        padding: "12dp"
        spacing: "10dp"

        MDLabel:
            text: "Ajouter une empreinte"
            theme_text_color: "Custom"
            text_color: app.primary
            font_style: "H6"
            halign: "center"
            size_hint_y: None
            height: "36dp"


        # menu déroulant pour filtrer par catégorie
        Spinner:
            id: category_spinner
            text: "Toutes"
            values: ["Toutes"]
            size_hint_y: None
            height: "40dp"
            background_color: app.secondary
            color: 1, 1, 1, 1
            on_text: root.rechercher()  # on relance la recherche quand on change de catégorie



        # barre de recherche textuelle
        MDBoxLayout:
            size_hint_y: None
            height: "48dp"
            spacing: "6dp"
            MDTextField:
                id: search_field
                hint_text: "Rechercher une activité…"
                on_text: root.rechercher()
                mode: "rectangle"


            MDIconButton:
                icon: "magnify"
                theme_icon_color: "Custom"
                icon_color: app.primary
                on_release: root.rechercher()

        # liste des activités (RecycleView pour les performances avec beaucoup d'éléments)
        RecycleView:
            id: activities_list
            size_hint_y: 0.45
            viewclass: "ActivityItem"  # on utilise notre widget ActivityItem pour chaque ligne
            RecycleBoxLayout:
                orientation: "vertical"
                spacing: "4dp"
                padding: "2dp"
                default_size_hint: 1, None
                default_size: None, "64dp"
                size_hint_y: None
                height: self.minimum_height



        # ligne de séparation
        MDSeparator:
            size_hint_y: None
            height: "1dp"

        # zone de validation de l'activité sélectionnée
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "120dp"
            spacing: "6dp"

            # affiche le nom de l'activité sélectionnée
            MDLabel:
                id: selected_label
                text: "Aucune activité sélectionnée"
                theme_text_color: "Custom"
                text_color: app.secondary
                font_size: "13sp"
                markup: True  # pour pouvoir mettre du texte en gras avec [b]
                halign: "center"
                size_hint_y: None
                height: "28dp"



            # champ pour entrer la quantité
            MDTextField:
                id: quantity_field
                hint_text: "Quantité"
                input_filter: "float"  # autorise seulement les nombres décimaux
                disabled: True         # désactivé tant qu'aucune activité n'est sélectionnée
                mode: "rectangle"
                size_hint_y: None
                height: "48dp"

            # bouton valider
            MDRaisedButton:
                id: valider_btn
                text: "Valider"
                md_bg_color: app.primary
                text_color: 1, 1, 1, 1
                disabled: True  # désactivé tant qu'aucune activité n'est sélectionnée
                size_hint_x: 1
                on_release: root.valider()

        # message de confirmation après validation
        MDLabel:
            id: feedback_label
            text: ""
            theme_text_color: "Custom"
            text_color: app.secondary
            font_size: "13sp"
            halign: "center"
            size_hint_y: None
            height: "24dp"











# ---- onglet classement ----
<LeaderboardTab>:
    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        orientation: "vertical"
        padding: "12dp"
        spacing: "10dp"


        MDBoxLayout:
            size_hint_y: None
            height: "48dp"
            spacing: "8dp"

            MDLabel:
                text: "Classement"
                theme_text_color: "Custom"
                text_color: app.primary
                font_style: "H6"
                halign: "center"

        MDBoxLayout:
            size_hint_y: None
            height: "48dp"
            spacing: "8dp"
            pos_hint: {"center_x": 0.65}
            size_hint_x: None
            width: "300dp"

            MDRaisedButton:
                text: "Total"
                pos_hint: {"center_y": 0.5}
                theme_icon_color: "Custom"
                icon_color: app.secondary
                size_hint_x: None
                width: "40dp"
                on_release: root.charger_classement()
            MDRaisedButton:
                text: "7 jours"
                pos_hint: {"center_y": 0.5}
                theme_icon_color: "Custom"
                icon_color: app.secondary
                size_hint_x: None
                width: "40dp"
                on_release: root.charger_classement(7)
            MDRaisedButton:
                text: "1 mois"
                pos_hint: {"center_y": 0.5}
                theme_icon_color: "Custom"
                icon_color: app.secondary
                size_hint_x: None
                width: "40dp"
                on_release: root.charger_classement(31)

        # petite explication des règles
        MDLabel:
            text: "Le moins de CO2 = le meilleur !"
            font_size: "12sp"
            theme_text_color: "Custom"
            text_color: app.secondary
            halign: "center"
            size_hint_y: None
            height: "24dp"

        MDSeparator:
            size_hint_y: None
            height: "1dp"

        # liste scrollable du classement


        ScrollView:
            RecycleView:
                id: leaderboard_list
                viewclass: "LeaderboardRow"  # on utilise notre widget LeaderboardRow
                RecycleBoxLayout:
                    orientation: "vertical"
                    spacing: "6dp"
                    padding: "4dp"
                    default_size_hint: 1, None
                    default_size: None, "60dp"
                    size_hint_y: None
                    height: self.minimum_height

