<MainScreen>:
    name: "main"

    canvas.before:
        Color:
            rgba: app.background
        Rectangle:
            pos: self.pos
            size: self.size

    MDBottomNavigation:
        id: bottom_nav
        panel_color: app.primary
        text_color_active: 1,1,1,1
        text_color_normal: app.accent

        HomeTab:
            name: "home"
            text: "Accueil"
            icon: "home"

        AddTab:
            name: "add"
            text: "Ajouter"
            icon: "plus"

        LeaderboardTab:
            name: "leaderboard"
            text: "Classement"
            icon: "trophy"

        ProfileTab:
            name: "profile"
            text: "Compte"
            icon: "account"


<HomeTab>:

    FloatLayout:

        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size


        MDIconButton:
            icon: "account-group"
            pos_hint: {"right": 1, "top": 1}
            theme_text_color: "Custom"
            text_color: app.primary
            on_release: app.menu_amis()

        MDLabel:
            text: "Page Accueil"
            halign: "center"


<ProfileTab>:

    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        # Titre
        MDLabel:
            text: "Mon Profil"
            theme_text_color: "Custom"
            text_color: app.primary
            font_style: "H5"
            halign: "center"
            size_hint_y: None
            height: "50dp"

        # Bouton déconnecter en haut
        MDRaisedButton:
            text: "Se déconnecter"
            md_bg_color: app.primary
            text_color: 1,1,1,1
            size_hint_x: 1
            on_release: app.deconnexion()

        # Carte profil
        MDCard:
            orientation: "vertical"
            padding: "20dp"
            spacing: "15dp"
            md_bg_color: app.background
            elevation: 1
            size_hint_y: None
            height: "280dp"

            # Nom d'utilisateur
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"

                MDLabel:
                    text: "Nom d'utilisateur"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"

                MDLabel:
                    text: app.username
                    theme_text_color: "Custom"
                    text_color: app.primary
                    font_style: "H6"
                    size_hint_y: None
                    height: "30dp"

            # Email
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"

                MDLabel:
                    text: "Email"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"

                MDLabel:
                    text: app.email
                    theme_text_color: "Custom"
                    text_color: app.secondary
                    font_size: "13sp"
                    size_hint_y: None
                    height: "30dp"

            # Nombre d'amis
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "70dp"
                spacing: "5dp"

                MDLabel:
                    text: "Nombre d'amis"
                    theme_text_color: "Hint"
                    font_size: "12sp"
                    size_hint_y: None
                    height: "20dp"

                MDLabel:
                    text: app.friends_count
                    theme_text_color: "Custom"
                    text_color: app.accent
                    font_style: "H6"
                    size_hint_y: None
                    height: "30dp"

        # Espace flexible pour pousser le contenu vers le haut
        Widget:


<AddTab>:
    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        orientation: "vertical"
        MDLabel:
            text: "Ajouter empreinte"
            halign: "center"


<LeaderboardTab>:
    MDBoxLayout:
        canvas.before:
            Color:
                rgba: app.background
            Rectangle:
                pos: self.pos
                size: self.size

        MDLabel:
            text: "Leaderboard"
            halign: "center"
